{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Daily Drinkers by State & Territory, 2022", "fontSize": 15, "font": "DM Sans", "color": "#1C1208", "anchor": "start"},
  "width": "container",
  "height": 500,
  "projection": {"type": "mercator", "center": [133, -27], "scale": 600},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/4_interactive_scatter_plot/js/WorldMapWithGraticules.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_1_states_provinces"}
      },
      "transform": [{"filter": "indexof(['New South Wales','Victoria','Queensland','South Australia','Western Australia','Tasmania','Northern Territory','Australian Capital Territory'], datum.properties.name) >= 0"}],
      "mark": {"type": "geoshape", "fill": "#f5e6c8", "stroke": "white", "strokeWidth": 1}
    },
    {
      "data": {
        "values": [
          {"state": "NSW", "lon": 146.5, "lat": -32.0, "daily": 4.8},
          {"state": "VIC", "lon": 144.5, "lat": -37.2, "daily": 4.0},
          {"state": "QLD", "lon": 145.0, "lat": -22.0, "daily": 5.6},
          {"state": "SA",  "lon": 135.5, "lat": -30.0, "daily": 5.5},
          {"state": "WA",  "lon": 121.5, "lat": -26.0, "daily": 5.8},
          {"state": "TAS", "lon": 146.5, "lat": -42.0, "daily": 5.2},
          {"state": "NT",  "lon": 133.5, "lat": -19.5, "daily": 7.2},
          {"state": "ACT", "lon": 149.1, "lat": -35.5, "daily": 4.5}
        ]
      },
      "mark": {"type": "circle", "opacity": 0.8, "color": "#D4692A", "stroke": "white", "strokeWidth": 2},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "daily", "type": "quantitative",
          "scale": {"domain": [3, 8], "range": [300, 3500]},
          "legend": {"title": "Daily Drinkers (%)", "labelFont": "DM Sans", "titleFont": "DM Sans"}
        },
        "tooltip": [{"field": "state", "title": "State"}, {"field": "daily", "title": "Daily drinkers %", "format": ".1f"}]
      }
    },
    {
      "data": {
        "values": [
          {"state": "NSW", "lon": 146.5, "lat": -32.0},
          {"state": "VIC", "lon": 144.5, "lat": -37.2},
          {"state": "QLD", "lon": 145.0, "lat": -22.0},
          {"state": "SA",  "lon": 135.5, "lat": -30.0},
          {"state": "WA",  "lon": 121.5, "lat": -26.0},
          {"state": "TAS", "lon": 146.5, "lat": -42.0},
          {"state": "NT",  "lon": 133.5, "lat": -19.5},
          {"state": "ACT", "lon": 149.1, "lat": -35.5}
        ]
      },
      "mark": {"type": "text", "fontSize": 11, "fontWeight": "bold", "color": "#3D2B0F", "font": "DM Sans", "dy": -22},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"}
      }
    }
  ],
  "config": {"view": {"stroke": null}, "background": "transparent"}
}
