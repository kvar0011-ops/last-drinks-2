{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Risky Drinking by State & Territory, 2022", "fontSize": 15, "font": "DM Sans", "color": "#1C1208", "anchor": "start"},
  "width": "container",
  "height": 500,
  "projection": {"type": "mercator", "center": [133, -27], "scale": 600},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/4_interactive_scatter_plot/js/WorldMapWithGraticules.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_1_states_provinces"}
      },
      "transform": [
        {"filter": "indexof(['New South Wales','Victoria','Queensland','South Australia','Western Australia','Tasmania','Northern Territory','Australian Capital Territory'], datum.properties.name) >= 0"},
        {"calculate": "datum.properties.name == 'New South Wales' ? 26.3 : datum.properties.name == 'Victoria' ? 23.8 : datum.properties.name == 'Queensland' ? 29.4 : datum.properties.name == 'South Australia' ? 29.3 : datum.properties.name == 'Western Australia' ? 29.9 : datum.properties.name == 'Tasmania' ? 26.8 : datum.properties.name == 'Northern Territory' ? 31.1 : 25.7", "as": "pct"},
        {"calculate": "datum.properties.name == 'New South Wales' ? 'NSW' : datum.properties.name == 'Victoria' ? 'VIC' : datum.properties.name == 'Queensland' ? 'QLD' : datum.properties.name == 'South Australia' ? 'SA' : datum.properties.name == 'Western Australia' ? 'WA' : datum.properties.name == 'Tasmania' ? 'TAS' : datum.properties.name == 'Northern Territory' ? 'NT' : 'ACT'", "as": "abbr"}
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "color": {
          "field": "pct",
          "type": "quantitative",
          "scale": {"type": "threshold", "domain": [24, 27, 29, 31], "range": ["#fde8c8", "#f5c88a", "#e09040", "#c86810", "#8B4500"]},
          "legend": {"title": "% Exceeding Guidelines", "orient": "bottom", "gradientLength": 220, "labelFont": "DM Sans", "titleFont": "DM Sans"}
        },
        "tooltip": [
          {"field": "properties.name", "title": "State/Territory"},
          {"field": "pct", "title": "% Exceeding", "format": ".1f"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"abbr": "NSW", "lon": 146.5, "lat": -32.0},
          {"abbr": "VIC", "lon": 144.5, "lat": -37.2},
          {"abbr": "QLD", "lon": 145.0, "lat": -22.0},
          {"abbr": "SA",  "lon": 135.5, "lat": -30.0},
          {"abbr": "WA",  "lon": 121.5, "lat": -26.0},
          {"abbr": "TAS", "lon": 146.5, "lat": -42.0},
          {"abbr": "NT",  "lon": 133.5, "lat": -19.5},
          {"abbr": "ACT", "lon": 149.1, "lat": -35.5}
        ]
      },
      "mark": {"type": "text", "fontSize": 12, "fontWeight": "bold", "color": "white", "font": "DM Sans"},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "abbr", "type": "nominal"}
      }
    }
  ],
  "config": {"view": {"stroke": null}, "background": "transparent"}
}
