{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Risky Drinking by State & Territory, 2022",
    "fontSize": 15,
    "font": "DM Sans",
    "color": "#1C1208",
    "anchor": "start"
  },
  "width": "container",
  "height": 360,
  "projection": {"type": "mercator"},
  "data": {
    "url": "js/australia_states.json",
    "format": {"type": "json", "property": "features"}
  },
  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {"url": "data/by_state.csv"},
        "key": "state",
        "fields": ["exceeded_pct", "state_abbr"]
      }
    }
  ],
  "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 1},
  "encoding": {
    "color": {
      "field": "exceeded_pct",
      "type": "quantitative",
      "scale": {
        "type": "threshold",
        "domain": [24, 27, 29, 31],
        "range": ["#fde8c8", "#f5c88a", "#e09040", "#c86810", "#8B4500"]
      },
      "legend": {
        "title": "% Exceeding Guidelines",
        "orient": "bottom",
        "gradientLength": 200,
        "labelFont": "DM Sans",
        "titleFont": "DM Sans"
      }
    },
    "tooltip": [
      {"field": "properties.STATE_NAME", "title": "State/Territory"},
      {"field": "exceeded_pct", "title": "% Exceeding Guideline", "format": ".1f"}
    ]
  },
  "config": {"view": {"stroke": null}, "background": "transparent"}
}
