{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Risky Drinking by State & Territory, 2022", "fontSize": 15, "font": "DM Sans", "color": "#1C1208", "anchor": "start"},
  "width": "container",
  "height": 500,
  "projection": {"type": "mercator", "center": [133, -27], "scale": 600},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/2_symbol_map/js/ne_110m_admin_0_countries.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "transform": [{"filter": "datum.properties.NAME == 'Australia'"}],
      "mark": {"type": "geoshape", "fill": "#f5e6c8", "stroke": "#ccc", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/4_interactive_scatter_plot/js/WorldMapWithGraticules.topojson",
        "format": {"type": "topojson", "feature": "ne_110m_admin_1_states_provinces"}
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "values": [
                {"state": "New South Wales", "pct": 26.3},
                {"state": "Victoria", "pct": 23.8},
                {"state": "Queensland", "pct": 29.4},
                {"state": "South Australia", "pct": 29.3},
                {"state": "Western Australia", "pct": 29.9},
                {"state": "Tasmania", "pct": 26.8},
                {"state": "Northern Territory", "pct": 31.1},
                {"state": "Australian Capital Territory", "pct": 25.7}
              ]
            },
            "key": "state",
            "fields": ["pct"]
          }
        },
        {"filter": "datum.pct != null"}
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "color": {
          "field": "pct",
          "type": "quantitative",
          "scale": {"type": "threshold", "domain": [24, 27, 29, 31], "range": ["#fde8c8", "#f5c88a", "#e09040", "#c86810", "#8B4500"]},
          "legend": {"title": "% Exceeding Guidelines", "orient": "bottom", "gradientLength": 220, "labelFont": "DM Sans", "titleFont": "DM Sans"}
        },
        "tooltip": [
          {"field": "properties.name", "title": "State/Territory"},
          {"field": "pct", "title": "% Exceeding", "format": ".1f"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"state": "NSW", "lon": 146.5, "lat": -32.0},
          {"state": "VIC", "lon": 144.5, "lat": -37.2},
          {"state": "QLD", "lon": 145.0, "lat": -22.0},
          {"state": "SA",  "lon": 135.5, "lat": -30.0},
          {"state": "WA",  "lon": 121.5, "lat": -26.0},
          {"state": "TAS", "lon": 146.5, "lat": -42.0},
          {"state": "NT",  "lon": 133.5, "lat": -19.5},
          {"state": "ACT", "lon": 149.1, "lat": -35.5}
        ]
      },
      "mark": {"type": "text", "fontSize": 12, "fontWeight": "bold", "color": "white", "font": "DM Sans"},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"}
      }
    }
  ],
  "config": {"view": {"stroke": null}, "background": "transparent"}
}
