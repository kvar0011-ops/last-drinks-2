{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Risky Drinking by State & Territory, 2022",
    "fontSize": 15,
    "font": "DM Sans",
    "color": "#1C1208",
    "anchor": "start"
  },
  "width": "container",
  "height": 420,
  "projection": {
    "type": "mercator",
    "center": [
      133,
      -28
    ],
    "scale": 650
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.min.geojson"
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {
              "values": [
                {
                  "state": "New South Wales",
                  "pct": 26.3
                },
                {
                  "state": "Victoria",
                  "pct": 23.8
                },
                {
                  "state": "Queensland",
                  "pct": 29.4
                },
                {
                  "state": "South Australia",
                  "pct": 29.3
                },
                {
                  "state": "Western Australia",
                  "pct": 29.9
                },
                {
                  "state": "Tasmania",
                  "pct": 26.8
                },
                {
                  "state": "Northern Territory",
                  "pct": 31.1
                },
                {
                  "state": "Australian Capital Territory",
                  "pct": 25.7
                }
              ]
            },
            "key": "state",
            "fields": [
              "pct"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "color": {
          "field": "pct",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [
              24,
              27,
              29,
              31
            ],
            "range": [
              "#fde8c8",
              "#f5c88a",
              "#e09040",
              "#c86810",
              "#8B4500"
            ]
          },
          "legend": {
            "title": "% Exceeding Guidelines",
            "orient": "bottom",
            "gradientLength": 220,
            "labelFont": "DM Sans",
            "titleFont": "DM Sans"
          }
        },
        "tooltip": [
          {
            "field": "properties.STATE_NAME",
            "title": "State/Territory"
          },
          {
            "field": "pct",
            "title": "% Exceeding",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "abbr": "NSW",
            "lon": 146.5,
            "lat": -32.5
          },
          {
            "abbr": "VIC",
            "lon": 144.5,
            "lat": -37
          },
          {
            "abbr": "QLD",
            "lon": 144.5,
            "lat": -22.5
          },
          {
            "abbr": "SA",
            "lon": 135,
            "lat": -30
          },
          {
            "abbr": "WA",
            "lon": 121.5,
            "lat": -26
          },
          {
            "abbr": "TAS",
            "lon": 146.5,
            "lat": -42
          },
          {
            "abbr": "NT",
            "lon": 133,
            "lat": -19.5
          },
          {
            "abbr": "ACT",
            "lon": 149.1,
            "lat": -35.5
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "font": "DM Sans",
        "color": "white"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "abbr",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "transparent"
  }
}
