{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Alcohol-Related Hospitalisations, 2015–2024", "fontSize": 15, "font": "DM Sans", "color": "#1C1208", "anchor": "start"},
  "width": "container",
  "height": 280,
  "data": {"url": "data/hospitalisations.csv"},
  "layer": [
    {
      "mark": {"type": "bar", "color": "#B8841A", "opacity": 0.3, "cornerRadiusTopLeft": 4, "cornerRadiusTopRight": 4},
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "axis": {"labelAngle": -45, "labelFontSize": 10, "title": null}},
        "y": {"field": "alcohol_related", "type": "quantitative", "title": "Alcohol-Related Admissions"}
      }
    },
    {
      "mark": {"type": "line", "color": "#D4692A", "strokeWidth": 3},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "alcohol_related", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "title": "Year"},
          {"field": "alcohol_related", "title": "Hospitalisations", "format": ",d"}
        ]
      }
    },
    {
      "mark": {"type": "point", "color": "#D4692A", "filled": true, "size": 70},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "alcohol_related", "type": "quantitative"}
      }
    },
    {
      "transform": [{"filter": "datum.year === '2020-21'"}],
      "mark": {"type": "text", "dy": -15, "fontSize": 11, "fontWeight": "bold", "color": "#D4692A", "font": "DM Sans"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "alcohol_related", "type": "quantitative"},
        "text": {"value": "COVID spike"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "background": "transparent",
    "axis": {"gridColor": "#ede3cc", "domainColor": "#c8b88a", "labelColor": "#5A4020", "titleColor": "#5A4020", "labelFont": "DM Sans", "titleFont": "DM Sans"}
  }
}
